#!/usr/bin/env python3
"""
webcat — `cat` for the web. Render web pages and markdown in your terminal,
with real inline images.

Pipeline: defuddle (URL -> clean markdown) -> glow (text) + chafa (images),
stitched together in document order so images appear where they belong.
Images render with whatever graphics protocol your terminal supports
(kitty / sixel / iTerm2), auto-detected by chafa, with a Unicode-block
fallback for plain terminals. Every image type renders, including SVG
(rasterized via rsvg-convert / ImageMagick) and data: URIs. Small images keep
their natural size; large/tall ones are scaled down to fit.

Usage:
    webcat <url>                 # fetch a web page, render text + images
    webcat <file.md>             # render a local markdown file
    cat file.md | webcat         # render markdown from stdin
    webcat <url> -w 100          # set render width in columns
    webcat <url> --img-height 16 # cap large-image height (rows)
    webcat <url> --no-images     # text only (skip image download/render)

Dependencies: defuddle (for URLs), glow (text), chafa (images),
optionally librsvg/ImageMagick (for SVG). Run ./install.sh, or see the README.
"""
import argparse
import hashlib
import os
import re
import shutil
import struct
import subprocess
import sys
import tempfile
import urllib.error
import urllib.parse
import urllib.request

__version__ = "0.7.0"

IMG_RE = re.compile(r'!\[[^\]]*\]\(\s*(<[^>]+>|[^)\s]+)(?:\s+"[^"]*")?\s*\)')

# Tools may live outside PATH (e.g. a cargo-installed mdcat in ~/.cargo/bin).
EXTRA_BIN = [os.path.expanduser("~/.cargo/bin")]


def die(msg, code=1):
    sys.stderr.write(f"webcat: {msg}\n")
    sys.exit(code)


def which(tool):
    found = shutil.which(tool)
    if found:
        return found
    for d in EXTRA_BIN:
        cand = os.path.join(d, tool)
        if os.path.isfile(cand) and os.access(cand, os.X_OK):
            return cand
    return None


def have(tool):
    return which(tool) is not None


def run_defuddle(url):
    """Convert a URL to clean markdown via the defuddle CLI.

    Falls back to running the resolved CLI through node, which sidesteps the
    `/usr/bin/env` shebang problem on platforms like Termux.
    """
    if not have("defuddle"):
        die("`defuddle` not found (needed for URLs). Run install.sh or "
            "`npm install -g defuddle`.")
    attempts = [["defuddle", "parse", url, "--md"]]
    real = shutil.which("defuddle")
    target = os.path.realpath(real) if real else None
    if target and have("node"):
        attempts.append(["node", target, "parse", url, "--md"])
    last = None
    for cmd in attempts:
        try:
            r = subprocess.run(cmd, capture_output=True, text=True)
        except OSError as e:
            last = str(e)
            continue
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout
        last = r.stderr.strip() or f"exit {r.returncode}"
    die(f"defuddle failed for {url}: {last}")


def get_markdown(src):
    if src is None or src == "-":
        return sys.stdin.read()
    if re.match(r'^https?://', src):
        return run_defuddle(src)
    try:
        with open(src, "r", encoding="utf-8", errors="replace") as f:
            return f.read()
    except OSError as e:
        die(f"cannot read {src}: {e}")


def absolutize_images(md, base_url):
    """Rewrite relative image URLs to absolute so backends can fetch them."""
    if not base_url:
        return md

    def repl(m):
        url = m.group(1)
        bare = url[1:-1] if url.startswith("<") and url.endswith(">") else url
        if bare.startswith("//"):
            new = "https:" + bare
        elif not re.match(r'^https?://', bare):
            new = urllib.parse.urljoin(base_url, bare)
        else:
            new = bare
        return m.group(0).replace(url, new, 1)

    return IMG_RE.sub(repl, md)


def render_with_mdcat(md, base_url, width):
    """Render the whole document (text + inline images) with mdcat in one pass."""
    md = absolutize_images(md, base_url)
    cmd = [which("mdcat"), "--columns", str(width)]
    proc = subprocess.run(cmd, input=md, text=True)
    return proc.returncode == 0


def render_text(md, width):
    if not md.strip():
        return
    if have("glow"):
        subprocess.run(["glow", "-w", str(width), "-"], input=md, text=True)
    else:
        sys.stdout.write(md)  # graceful fallback: raw markdown


def _looks_like_svg(head):
    s = head.lstrip()[:512].lower()
    return s.startswith(b"<svg") or (s.startswith(b"<?xml") and b"<svg" in s)


def _looks_like_html(head):
    s = head.lstrip()[:64].lower()
    return s.startswith((b"<!doctype html", b"<html"))


def rasterize_svg(src):
    """Convert an SVG to PNG so chafa can render it. Returns a PNG path or None.

    Tries rsvg-convert (librsvg) first, then ImageMagick (magick/convert).
    """
    out = src + ".png"
    rsvg = which("rsvg-convert")
    if rsvg:
        try:
            r = subprocess.run([rsvg, "-w", "640", src, "-o", out],
                               timeout=30, capture_output=True)
            if r.returncode == 0 and os.path.getsize(out) > 0:
                return out
        except Exception:
            pass
    for name in ("magick", "convert"):
        im = which(name)
        if not im:
            continue
        try:
            r = subprocess.run(
                [im, "-background", "none", "-density", "150", src, out],
                timeout=30, capture_output=True)
            if r.returncode == 0 and os.path.exists(out) and os.path.getsize(out) > 0:
                return out
        except Exception:
            pass
    return None


def _decode_data_uri(url):
    """Decode a data: URI into (bytes, suffix). Returns None if not a data URI."""
    if not url.startswith("data:"):
        return None
    meta, _, payload = url[5:].partition(",")
    if not payload and "," not in url[5:]:
        return None
    media = meta.split(";")[0].lower()
    ext = {"image/png": ".png", "image/jpeg": ".jpg", "image/gif": ".gif",
           "image/webp": ".webp", "image/svg+xml": ".svg",
           "image/bmp": ".bmp"}.get(media, ".img")
    try:
        if ";base64" in meta.lower():
            import base64
            return base64.b64decode(payload), ext
        return urllib.parse.unquote_to_bytes(payload), ext
    except Exception:
        return None


def localize(url, base_url, base_dir):
    """Resolve an image reference to a local file path (downloading if needed).

    Handles data: URIs, http(s) URLs, protocol-relative //urls, and local
    files referenced from a local markdown source. Returns a path or None.
    """
    if url.startswith("<") and url.endswith(">"):
        url = url[1:-1]

    data = _decode_data_uri(url)
    if data is not None:
        payload, ext = data
        tmp = os.path.join(tempfile.gettempdir(),
                           "webcat-" + hashlib.sha1(payload).hexdigest()[:12] + ext)
        with open(tmp, "wb") as f:
            f.write(payload)
        return tmp

    if url.startswith("//"):
        url = "https:" + url
    elif base_url and not re.match(r'^https?://', url):
        url = urllib.parse.urljoin(base_url, url)

    if re.match(r'^https?://', url):
        path = urllib.parse.urlparse(url).path
        suffix = os.path.splitext(path)[1] or ".img"
        tmp = os.path.join(tempfile.gettempdir(),
                           "webcat-" + hashlib.sha1(url.encode()).hexdigest()[:12] + suffix)
        if not os.path.exists(tmp):
            headers = {
                "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 "
                              "(KHTML, like Gecko) Chrome/124.0 Safari/537.36",
                "Accept": "image/avif,image/webp,image/png,image/*,*/*;q=0.8",
            }
            # Many CDNs hotlink-protect images: they only serve them when the
            # request's Referer/Origin matches the embedding page. Send the page
            # URL (or the image's own origin) so those requests succeed.
            ref = base_url or url
            headers["Referer"] = ref
            origin = urllib.parse.urlparse(ref)
            headers["Origin"] = f"{origin.scheme}://{origin.netloc}"
            req = urllib.request.Request(url, headers=headers)
            with urllib.request.urlopen(req, timeout=20) as r, open(tmp, "wb") as f:
                f.write(r.read())
        return tmp

    # A local file path (relative to the markdown's directory, or absolute).
    local = url if os.path.isabs(url) else os.path.join(base_dir or "", url)
    return local if os.path.isfile(local) else None


def _jpeg_size(path):
    try:
        with open(path, "rb") as f:
            f.read(2)
            while True:
                b = f.read(1)
                if not b:
                    return None
                if b != b"\xff":
                    continue
                marker = f.read(1)
                while marker == b"\xff":
                    marker = f.read(1)
                if marker[0] in (0xC0, 0xC1, 0xC2, 0xC3, 0xC5, 0xC6, 0xC7,
                                 0xC9, 0xCA, 0xCB, 0xCD, 0xCE, 0xCF):
                    f.read(3)
                    h, w = struct.unpack(">HH", f.read(4))
                    return w, h
                ln = struct.unpack(">H", f.read(2))[0]
                f.seek(ln - 2, 1)
    except Exception:
        return None


def image_size(path):
    """Return (width, height) in pixels, or None. Pure-header for common
    formats; falls back to ImageMagick `identify`."""
    try:
        with open(path, "rb") as f:
            h = f.read(32)
    except Exception:
        return None
    if h[:8] == b"\x89PNG\r\n\x1a\n":
        return struct.unpack(">II", h[16:24])
    if h[:6] in (b"GIF87a", b"GIF89a"):
        return struct.unpack("<HH", h[6:10])
    if h[:2] == b"BM":
        w, ht = struct.unpack("<ii", h[18:26])
        return abs(w), abs(ht)
    if h[:2] == b"\xff\xd8":
        return _jpeg_size(path)
    im = which("identify")
    if im:
        r = subprocess.run([im, "-format", "%w %h", path + "[0]"],
                           capture_output=True, text=True)
        try:
            w, ht = r.stdout.split()[:2]
            return int(w), int(ht)
        except Exception:
            pass
    return None


def render_image(url, base_url, base_dir, width, height, threshold):
    chafa = which("chafa")
    if not chafa:
        return
    try:
        tmp = localize(url, base_url, base_dir)
        if not tmp:
            return
        with open(tmp, "rb") as f:
            head = f.read(512)

        render_src = tmp
        if tmp.lower().endswith(".svg") or _looks_like_svg(head):
            png = rasterize_svg(tmp)
            if not png:
                sys.stderr.write(
                    f"[webcat: cannot rasterize SVG {url} — install librsvg "
                    f"or imagemagick]\n")
                return
            render_src = png
        elif _looks_like_html(head):
            return  # an HTML error page, not an image

        # Cap width at the real terminal width so nothing overflows.
        cols = shutil.get_terminal_size((80, 24)).columns
        maxw = max(20, min(width, cols))
        box = f"{maxw}x{height}"

        # Small images (icons/badges) below the pixel threshold keep their true
        # natural size — never enlarged — via --view-size (fit-down-only).
        # Larger content images are scaled UP to fill the width via --size, so
        # they're not tiny on high-DPI screens. Aspect ratio is preserved.
        dims = image_size(render_src)
        is_small = dims is not None and dims[0] < threshold and dims[1] < threshold
        if is_small:
            cmd = ["chafa", "--view-size", box, render_src]
        else:
            cmd = ["chafa", "--size", box, render_src]
        subprocess.run(cmd, timeout=30)
    except urllib.error.HTTPError as e:
        if e.code in (401, 403):
            reason = ("access denied — hotlink-protected or an expired/signed "
                      "link that only works from the original page")
        elif e.code == 404:
            reason = "not found (404)"
        else:
            reason = f"HTTP {e.code}"
        sys.stderr.write(f"[webcat: skipped image — {reason}]\n")
    except Exception as e:
        sys.stderr.write(f"[webcat: skipped image {url}: {e}]\n")


def main():
    p = argparse.ArgumentParser(
        prog="webcat",
        description="cat for the web — render pages & markdown with inline images.",
    )
    p.add_argument("source", nargs="?",
                   help="URL, markdown file, or omit to read stdin")
    p.add_argument("-w", "--width", type=int, default=100,
                   help="render width in columns (default: 100)")
    p.add_argument("--img-height", type=int, default=24, metavar="ROWS",
                   help="max image height in rows (default: 24); caps large "
                        "images that are scaled up to fill the width.")
    p.add_argument("--img-threshold", type=int, default=200, metavar="PX",
                   help="images smaller than this (both dimensions, in pixels) "
                        "keep their true size and are never enlarged; larger "
                        "ones scale up to fill the width (default: 200)")
    p.add_argument("--no-images", action="store_true",
                   help="skip images, render text only")
    p.add_argument("--engine", choices=["auto", "mdcat", "stitch"], default="stitch",
                   help="rendering backend: stitch (glow+chafa, default — most "
                        "compatible), mdcat (native single-pass, needs a terminal "
                        "mdcat supports), or auto (mdcat if available, else stitch)")
    p.add_argument("-V", "--version", action="version",
                   version=f"webcat {__version__}")
    args = p.parse_args()

    is_url = bool(args.source and re.match(r'^https?://', args.source))
    base_url = args.source if is_url else ""
    # For a local markdown file, resolve relative image paths against its dir.
    base_dir = (os.path.dirname(os.path.abspath(args.source))
                if args.source and not is_url and os.path.isfile(args.source) else "")
    md = get_markdown(args.source)

    # Pick the backend. mdcat renders text + images natively in one pass;
    # the stitch backend pairs glow (text) with chafa (images).
    use_mdcat = (
        not args.no_images
        and args.engine in ("auto", "mdcat")
        and have("mdcat")
    )
    if args.engine == "mdcat" and not have("mdcat"):
        die("--engine mdcat requested but mdcat not found")
    if use_mdcat and render_with_mdcat(md, base_url, args.width):
        return

    if args.no_images:
        render_text(md, args.width)
        return

    pos = 0
    for m in IMG_RE.finditer(md):
        render_text(md[pos:m.start()], args.width)
        render_image(m.group(1), base_url, base_dir, args.width,
                     args.img_height, args.img_threshold)
        pos = m.end()
    render_text(md[pos:], args.width)


if __name__ == "__main__":
    main()
